# Copy to `.env` and fill in the values. .env is gitignored.

# Anthropic Claude API key — used by admin_bot.py for the WhatsApp bot.
ANTHROPIC_API_KEY=sk-ant-api03-...

# CourtReserve (the club's member portal) login.
# URL is the portal index page; find the numeric suffix on your own club's URL.
COURTRESERVE_URL=https://app.courtreserve.com/Online/Portal/Index/XXXX
COURTRESERVE_USERNAME=you@example.com
COURTRESERVE_PASSWORD=your-password

# Google Sheet that acts as the player roster.
# See docs/google_sheets_setup.md for how to get the ID.
GOOGLE_SHEET_ID=your-sheet-id-here
